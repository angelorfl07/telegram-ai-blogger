{
  "name": "telegram-ai-blogger",
  "version": "1.0.0",
  "description": "Robô Telegram com Gemini PRO, SEO avançado e publicação automática no Ghost CMS.",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "lint": "tsc --noEmit",
    "db:inspect": "node -e \"const Database=require('better-sqlite3'); const db=new Database(process.env.SQLITE_PATH||'./storage/database.sqlite'); console.log(db.prepare('select * from posts order by created_at desc limit 10').all())\""
  },
  "keywords": ["telegram", "ghost", "gemini", "seo", "blog", "automation"],
  "author": "Manus AI",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.9",
    "better-sqlite3": "^11.7.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "form-data": "^4.0.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "marked": "^15.0.6",
    "sanitize-html": "^2.14.0",
    "sharp": "^0.33.5",
    "slugify": "^1.6.6",
    "telegraf": "^4.16.3",
    "winston": "^3.17.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.5",
    "@types/sanitize-html": "^2.13.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
